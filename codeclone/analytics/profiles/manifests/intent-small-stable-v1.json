  "primary_space": {
    "pca_dimensions": [64, 128],
    "min_cluster_size": [12, 15, 20],
    "min_samples": [3, 5],
    "cluster_selection_method": ["eom", "leaf"]
  },
  "suitability": {
    "min_non_noise_cluster_count": 2,
    "max_non_noise_cluster_count": 8,
    "max_dominant_cluster_ratio": 0.85,
    "min_noise_ratio": 0.05,
    "max_noise_ratio": 0.55,
    "min_non_noise_count": 40
  },
  "ranking": {
    "base_score_weight": 0.6,
    "cluster_count_weight": 0.2,
    "cluster_count_direction": "prefer_lower",
    "noise_weight": 0.2,
    "noise_direction": "prefer_lower"
  }
